__pycache__/
*.py[cod]
*.so
.venv/
venv/
dist/
*.egg-info/
.eggs/

# ── uv ───────────────────────────────────────────────────────────────────────
.uv/

# ── pytest / coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDE / tooling ────────────────────────────────────────────────────────────
.idea/
.vscode/
.claude/
*.swp
*.swo

