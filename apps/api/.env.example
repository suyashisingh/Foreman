# Copy to .env and fill in real values. Never commit .env.
DATABASE_URL=postgresql+asyncpg://foreman:foreman_secret@localhost:5434/foreman
REDIS_URL=redis://localhost:6380
ENVIRONMENT=development
LOG_LEVEL=INFO
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME
# Voyage AI — get a key at https://www.voyageai.com
VOYAGE_API_KEY=CHANGE_ME
VOYAGE_MODEL=voyage-code-3
REPO_CLONE_DIR=/tmp/foreman-repos
# Google Gemini — get a key at https://aistudio.google.com
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL=gemini-3.1-flash-lite
# LLM provider selector — only "gemini" is implemented; extend get_llm_client() for others
LLM_PROVIDER=gemini
# Maximum Coder<->Tester retry iterations (Day 4 retry loop)
MAX_CODER_RETRIES=2
# Maximum tool-call iterations within a single Coder invocation (inner loop bound)
MAX_CODER_TOOL_ITERATIONS=15
# e2b sandbox — get a key at https://e2b.dev
E2B_API_KEY=CHANGE_ME
# Comma-separated allowed CORS origins (set to your frontend domain in production)
ALLOWED_ORIGINS=http://localhost:3000
