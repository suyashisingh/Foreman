# Copy to .env and fill in real values. Never commit .env.
DATABASE_URL=postgresql+asyncpg://foreman:foreman_secret@localhost:5434/foreman
REDIS_URL=redis://localhost:6380
ENVIRONMENT=development
LOG_LEVEL=INFO
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME
# Voyage AI — get a key at https://www.voyageai.com
VOYAGE_API_KEY=CHANGE_ME
VOYAGE_MODEL=voyage-code-3
REPO_CLONE_DIR=/tmp/foreman-repos
# Google Gemini — get a key at https://aistudio.google.com
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL=gemini-2.5-flash
# LLM provider selector — only "gemini" is implemented; extend get_llm_client() for others
LLM_PROVIDER=gemini
# Maximum times the Coder node retries before giving up (used in Part 2)
MAX_CODER_RETRIES=2
