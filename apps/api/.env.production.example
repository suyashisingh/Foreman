# Production environment variables for the Foreman API.
# Copy this to .env on your Render service (or set via Render dashboard).
# Never commit a file containing real values.

# Neon Postgres — use the pooled connection string; ssl=require is mandatory.
DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname?ssl=require

# Upstash Redis — use the rediss:// (TLS) URL from the Upstash console.
REDIS_URL=rediss://default:pass@host:6379

# Google Gemini (https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash-lite

# Voyage AI (https://dash.voyageai.com)
VOYAGE_API_KEY=your-voyage-key
VOYAGE_MODEL=voyage-code-3

# e2b sandbox (https://e2b.dev)
E2B_API_KEY=your-e2b-key

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=generate-a-long-random-string

# Comma-separated list of allowed frontend origins (no trailing slash).
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app

# Optional overrides
ENVIRONMENT=production
LOG_LEVEL=INFO
