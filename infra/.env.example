# Copy this file to infra/.env and fill in values before running docker-compose.
# Never commit infra/.env to version control.

# PostgreSQL
POSTGRES_USER=foreman
POSTGRES_PASSWORD=foreman_secret
POSTGRES_DB=foreman

# Derived URLs — used by the API app (not docker-compose itself)
# DATABASE_URL=postgresql+asyncpg://foreman:foreman_secret@localhost:5434/foreman
# REDIS_URL=redis://localhost:6380
